---
import '~/assets/styles/tailwind.css';

import CommonMeta from '~/components/common/CommonMeta.astro';
import Favicons from '~/components/Favicons.astro';
import CustomStyles from '~/components/CustomStyles.astro';
import ApplyColorMode from '~/components/common/ApplyColorMode.astro';
import Metadata from '~/components/common/Metadata.astro';
import SiteVerification from '~/components/common/SiteVerification.astro';
import Analytics from '~/components/common/Analytics.astro';
import BasicScripts from '~/components/common/BasicScripts.astro';
import Doodles from '~/components/Doodles.astro';

// Comment the line below to disable View Transitions
import { ClientRouter } from 'astro:transitions';

import type { MetaData as MetaDataType } from '~/types';

export interface Props {
  metadata?: MetaDataType;
}

const { metadata = {} } = Astro.props;
---

<!doctype html>
<html lang="es" class="light 2xl:text-[20px]">
  <head>
    <CommonMeta />
    <Favicons />
    <CustomStyles />
    <ApplyColorMode />
    <Metadata {...metadata} />
    <SiteVerification />
    <Analytics />

    <!-- Animate.css for fluidity -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

    <!-- Comment the line below to disable View Transitions -->
    <ClientRouter fallback="swap" />
  </head>

  <body class="antialiased text-default bg-page tracking-tight overflow-x-hidden">
    <!-- Animated Background Doodles -->
    <div class="fixed inset-0 -z-10 pointer-events-none opacity-[0.07] overflow-hidden">
      <Doodles type="meditation" class="absolute top-[15%] left-[5%] w-64 h-64 animate-float-slow text-secondary" />
      <Doodles type="stretching" class="absolute bottom-[25%] right-[8%] w-72 h-72 animate-float-reverse text-primary" />
      <Doodles type="nutrition" class="absolute top-[40%] right-[3%] w-56 h-56 animate-float-slow text-accent" />
      <Doodles type="child" class="absolute bottom-[10%] left-[10%] w-60 h-60 animate-float-reverse text-secondary" />
    </div>

    <slot />

    <!-- Floating Social Buttons (Global) -->
    <div class="fixed bottom-6 right-6 z-50 flex flex-col gap-3 items-center animate__animated animate__bounceInUp">
      <!-- Email -->
      <a
        href="mailto:aepi.sociedad@gmail.com"
        class="bg-secondary text-white p-3 rounded-full shadow-lg hover:scale-110 transition-transform flex items-center justify-center"
        aria-label="Email"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
          <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
          <path d="M3 7a2 2 0 0 1 2 -2h14a2 2 0 0 1 2 2v10a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-10z"></path>
          <path d="M3 7l9 6l9 -6"></path>
        </svg>
      </a>
      <!-- Instagram -->
      <a
        href="https://www.instagram.com/contagiandobienestar"
        target="_blank"
        class="bg-gradient-to-tr from-[#f9ce34] via-[#ee2a7b] to-[#6228d7] text-white p-3 rounded-full shadow-lg hover:scale-110 transition-transform flex items-center justify-center"
        aria-label="Instagram"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
          <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
          <path d="M4 4m0 4a4 4 0 0 1 4 -4h8a4 4 0 0 1 4 4v8a4 4 0 0 1 -4 4h-8a4 4 0 0 1 -4 -4z"></path>
          <path d="M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0"></path>
          <path d="M16.5 7.5l0 .01"></path>
        </svg>
      </a>
      <!-- Facebook -->
      <a
        href="https://www.facebook.com/aepi.sociedad"
        target="_blank"
        class="bg-[#1877F2] text-white p-3 rounded-full shadow-lg hover:scale-110 transition-transform flex items-center justify-center"
        aria-label="Facebook"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
          <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
          <path d="M7 10v4h3v7h4v-7h3l1 -4h-4v-2a1 1 0 0 1 1 -1h3v-4h-3a5 5 0 0 0 -5 5v2h-3"></path>
        </svg>
      </a>
      <!-- WhatsApp -->
      <a
        href="https://wa.me/525520381691"
        target="_blank"
        class="bg-green-500 text-white p-4 rounded-full shadow-lg hover:scale-110 transition-transform flex items-center justify-center"
        aria-label="WhatsApp"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
          <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
          <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path>
          <path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"></path>
        </svg>
      </a>
    </div>

    <BasicScripts />

    <!-- Global Click Effect Script -->
    <script is:inline>
      document.addEventListener('click', (e) => {
        const target = e.target.closest('button, a');
        if (!target) return;

        const pulse = document.createElement('div');
        pulse.className = 'click-pulse';
        pulse.style.left = `${e.clientX}px`;
        pulse.style.top = `${e.clientY}px`;
        document.body.appendChild(pulse);

        setTimeout(() => pulse.remove(), 600);
      });
    </script>

    <style is:global>
      .click-pulse {
        position: fixed;
        width: 20px;
        height: 20px;
        background: rgba(233, 30, 99, 0.4);
        border-radius: 50%;
        pointer-events: none;
        transform: translate(-50%, -50%);
        animation: pulse-out 0.6s ease-out forwards;
        z-index: 10000;
      }

      @keyframes pulse-out {
        0% { transform: translate(-50%, -50%) scale(0); opacity: 1; }
        100% { transform: translate(-50%, -50%) scale(4); opacity: 0; }
      }

      @keyframes float-slow {
        0%, 100% { transform: translateY(0) rotate(0); }
        50% { transform: translateY(-40px) rotate(8deg); }
      }
      @keyframes float-reverse {
        0%, 100% { transform: translateY(0) rotate(0); }
        50% { transform: translateY(40px) rotate(-8deg); }
      }
      .animate-float-slow { animation: float-slow 12s ease-in-out infinite; }
      .animate-float-reverse { animation: float-reverse 15s ease-in-out infinite; }
    </style>
  </body>
</html>
