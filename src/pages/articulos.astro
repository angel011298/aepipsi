---
import Layout from '~/layouts/PageLayout.astro';
import HeroText from '~/components/widgets/HeroText.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';

const metadata = {
  title: 'Artículos de Bienestar | AEPI',
};

// Fetch dynamic articles from Content Collection
const posts = await getCollection('post');

// Sort by date if available
const sortedPosts = posts.sort((a, b) => 
  (b.data.publishDate?.getTime() || 0) - (a.data.publishDate?.getTime() || 0)
);
---

<Layout metadata={metadata}>
  <HeroText
    tagline="Conocimiento para tu Bienestar"
    title="Artículos e Investigación"
    subtitle="Explora nuestra colección de artículos especializados sobre salud mental, desarrollo infantil y gestión profesional."
  />

  <section class="relative px-4 py-16 sm:px-6 mx-auto lg:px-8 lg:py-20 max-w-4xl z-10">
    <div class="space-y-6">
      {sortedPosts.map((post) => (
        <details class="group bg-white/80 backdrop-blur-sm rounded-4xl border border-pink-100 shadow-sm p-6 hover:shadow-md transition-all duration-300 animate__animated animate__fadeInUp">
          <summary class="flex items-center justify-between cursor-pointer list-none">
            <div class="flex items-center gap-4">
              <div class="p-3 bg-pink-50 rounded-2xl text-secondary group-hover:bg-primary group-hover:text-white transition-colors duration-300">
                <Icon name={post.data.category === 'salud' ? 'tabler:activity' : 'tabler:file-description'} class="w-6 h-6" />
              </div>
              <h3 class="text-xl font-bold text-heading group-open:text-primary transition-colors">
                {post.data.title}
              </h3>
            </div>
            <span class="transition group-open:rotate-180">
              <Icon name="tabler:chevron-down" class="w-6 h-6 text-muted" />
            </span>
          </summary>
          <div class="mt-6 pt-6 border-t border-pink-50 text-default leading-relaxed prose prose-pink max-w-none animate__animated animate__fadeIn">
             {post.data.image && (
                <img src={post.data.image} alt={post.data.title} class="w-full h-64 object-cover rounded-3xl mb-6 shadow-sm" />
             )}
             <div set:html={post.body} />
          </div>
        </details>
      ))}

      {sortedPosts.length === 0 && (
        <div class="text-center py-20 text-muted">
           No hay artículos disponibles por el momento.
        </div>
      )}
    </div>
  </section>

  <style>
    details > summary::-webkit-details-marker {
      display: none;
    }
  </style>

</Layout>
