---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Features2 from '~/components/widgets/Features2.astro';
import Content from '~/components/widgets/Content.astro';
import Pricing from '~/components/widgets/Pricing.astro';
import CallToAction from '~/components/widgets/CallToAction.astro';
import { getCollection } from 'astro:content';
import AnimatedIllustration from '~/components/AnimatedIllustration.astro';


const metadata = {
  title: 'AEPI - Centro Multidisciplinario | Amar y Educar con Psicología Integral',
  ignoreTitleTemplate: true,
};

const whatsappAdviceNumber = '525532005195';
const whatsappClinicNumber = '525520381691';

// Fetch dynamic content
const teamMembers = await getCollection('team');
const events = await getCollection('events');
---

<Layout metadata={metadata}>
  <!-- Hero Section -->
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Agendar Cita',
        href: `https://wa.me/${whatsappClinicNumber}`, 
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      { text: 'Ver Precios', href: '#precios' },
    ]}
    image={{ src: '~/assets/images/image-team.jpeg', alt: 'Equipo AEPI' }}
  >
    <Fragment slot="title">
      Un espacio para <span class="text-accent highlight">sanar y crecer</span>
    </Fragment>

    <Fragment slot="subtitle">
      <span class="animate__animated animate__fadeIn animate__delay-1s text-gray-800">
        En AEPI, brindamos atención multidisciplinaria con calidez humana. Psicología, Nutrición y Desarrollo Infantil en un solo lugar.
      </span>
    </Fragment>
  </Hero>

  <!-- Events Section -->
  {events.length > 0 && (
    <section id="eventos" class="relative py-16">
      <div class="max-w-7xl mx-auto px-4 sm:px-6">
        <div class="grid lg:grid-cols-2 gap-12 items-center">
          <div>
            <Features2
              title="Próximos Eventos"
              subtitle="Talleres, pláticas y actividades diseñadas para tu crecimiento y bienestar."
              tagline="Agenda"
              items={events.map((event) => ({
                title: event.data.title,
                description: `${new Date(event.data.eventDate).toLocaleDateString('es-MX', { day: 'numeric', month: 'long', year: 'numeric' })} <br> ${event.body}`,
                icon: 'tabler:calendar-event',
              }))}
              classes={{ container: 'p-0' }}
            />
          </div>
          <div class="hidden lg:block">
            <AnimatedIllustration type="group-therapy" class="w-full max-w-md mx-auto" />
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Compressed Services Grid -->
  <Features
    id="servicios"
    tagline="Nuestras Especialidades"
    title="Atención Integral para tu Bienestar"
    subtitle="Haz clic en cada servicio para ver más detalles y agendar."
    classes={{
      container: 'relative z-10 animate__animated animate__fadeInUp bg-white/80 backdrop-blur-sm rounded-3xl shadow-sm border border-pink-100 p-8 mb-12',
      title: 'text-secondary',
      items: {
        container: 'hover-scale soft-shadow bg-white border border-pink-100 p-6 rounded-4xl cursor-pointer transition-all duration-300',
        title: 'text-secondary font-bold',
      }
    }}
    items={[
      {
        title: 'Psicología Clínica',
        description: 'Terapia individual, de pareja, infantil y manejo emocional. <br> <a href="#psicologia-detalle" class="text-primary font-bold mt-2 inline-block">Ver detalles »</a>',
        icon: 'tabler:brain',
      },
      {
        title: 'Nutrición',
        description: 'Planes personalizados para un estilo de vida saludable. <br> <a href="#nutricion-detalle" class="text-primary font-bold mt-2 inline-block">Ver detalles »</a>',
        icon: 'tabler:apple',
      },
      {
        title: 'Fisioterapia',
        description: 'Rehabilitación física, masajes y prevención de lesiones. <br> <a href="#fisioterapia-detalle" class="text-primary font-bold mt-2 inline-block">Ver detalles »</a>',
        icon: 'tabler:stretching',
      },
      {
        title: 'Desarrollo Infantil',
        description: 'Terapia de lenguaje, estimulación y regularización. <br> <a href="#desarrollo-detalle" class="text-primary font-bold mt-2 inline-block">Ver detalles »</a>',
        icon: 'tabler:mood-boy',
      },
    ]}
  />

  <!-- Detailed Sections -->
  <div class="grid lg:grid-cols-2 gap-8 items-center max-w-7xl mx-auto px-4 sm:px-6">
    <Content
      id="psicologia-detalle"
      tagline="Detalle del Servicio"
      title="Psicología Clínica"
      items={[
        { title: 'Terapia Individual', description: 'Atención personalizada para adultos y jóvenes.' },
        { title: 'Terapia de Pareja', description: 'Espacio para mejorar la comunicación y el vínculo.' },
        { title: 'Manejo de Emociones', description: 'Especialistas en estrés, depresión y ansiedad.' },
      ]}
      image={{ src: 'https://images.unsplash.com/photo-1544027993-37dbfe43562a?auto=format&fit=crop&q=80&w=2070', alt: 'Psicologia' }}
    >
      <Fragment slot="content">
        <p class="mb-4">Nuestro enfoque empático te ayudará a encontrar las herramientas necesarias para tu equilibrio emocional.</p>
        <div class="flex flex-col sm:flex-row gap-4 mb-6">
          <a href="https://cal.com/aepi/psicologia" target="_blank" class="btn btn-primary">Agendar con Cal.com</a>
        </div>
      </Fragment>
    </Content>
    <div class="flex flex-col gap-8">
      <AnimatedIllustration type="psychologist" class="w-full max-w-xs mx-auto" />
      <AnimatedIllustration type="marriage-counseling" class="w-full max-w-xs mx-auto" />
    </div>
  </div>

  <!-- Team Section (Dynamic) -->
  <Features2
    id="equipo"
    title="Conoce a nuestro equipo"
    subtitle="Profesionales comprometidos con tu salud y bienestar integral."
    tagline="Especialistas"
    items={teamMembers.map((member) => ({
      title: member.data.title,
      description: member.data.role,
      image: member.data.image,
      icon: 'tabler:user-heart',
    }))}
  />

  <!-- Pricing Section -->
  <Pricing
    id="precios"
    title="Costos de Inversión en Salud"
    subtitle="Precios competitivos y transparencia para tu tranquilidad."
    prices={[
      {
        title: 'Psicología y Salud Mental',
        subtitle: 'Terapia individual, pareja y lenguaje',
        price: '450',
        period: 'desde',
        items: [
          { description: 'Terapia Individual: $450 - $800' },
          { description: 'Pareja: $600 - $1,200' },
          { description: 'Lenguaje: $500 - $900' },
          { description: 'Ansiedad/Depresión: $600 - $850' },
        ],
        callToAction: { text: 'Solicitar informes', href: `https://wa.me/${whatsappClinicNumber}`, target: '_blank' },
        hasRibbon: true,
        ribbonTitle: 'Más solicitado',
      },
      {
        title: 'Nutrición y Fisioterapia',
        subtitle: 'Bienestar físico y rehabilitación',
        price: '400',
        period: 'desde',
        items: [
          { description: 'Consulta Nutrición: $650 - $800' },
          { description: 'Fisioterapia: $450 - $750' },
          { description: 'Masajes Terapéuticos: $500 - $900' },
          { description: 'Prevención: Planes desde $1,500' },
        ],
        callToAction: { text: 'Ver paquetes', href: `https://wa.me/${whatsappClinicNumber}`, target: '_blank' },
      },
      {
        title: 'Desarrollo Infantil',
        subtitle: 'Regularización y talleres',
        price: '150',
        period: 'por hora',
        items: [
          { description: 'Regularización: $150 - $250 /hr' },
          { description: 'Paquetes mensuales: $1,000 - $1,800' },
          { description: 'Estimulación Temprana: $350 - $600' },
          { description: 'Talleres Parentales: Consultar' },
        ],
        callToAction: { text: 'Inscribir ahora', href: `https://wa.me/${whatsappClinicNumber}`, target: '_blank' },
      },
    ]}
  />

  <Features2
    title="Servicios Profesionales Adicionales"
    subtitle="Expertos a tu disposición para necesidades legales, fiscales y digitales."
    tagline="Servicios Especializados"
    columns={3}
    classes={{
      container: 'animate__animated animate__fadeInUp bg-white/50 backdrop-blur-sm p-8 rounded-4xl mt-12',
      title: 'text-secondary',
      items: {
        container: 'hover-scale soft-shadow bg-white p-6 rounded-4xl border border-pink-100',
        title: 'text-secondary font-bold',
      }
    }}
    items={[
      {
        title: 'Asesoría Jurídica',
        description: 'Consulta inicial: $500 - $1,500 MXN.',
        icon: 'tabler:gavel',
        callToAction: {
          text: 'Contactar Asesor',
          href: `https://wa.me/${whatsappAdviceNumber}`,
          target: '_blank',
        }
      },
      {
        title: 'Asesoría Fiscal',
        description: 'Honorarios mensuales: $800 - $2,500 MXN.',
        icon: 'tabler:calculator',
        callToAction: {
          text: 'Contactar Asesor',
          href: `https://wa.me/${whatsappAdviceNumber}`,
          target: '_blank',
        }
      },
      {
        title: 'Desarrollo Web',
        description: 'Landings desde $2,200. Sitios Corporativos desde $8,000.',
        icon: 'tabler:code',
        callToAction: {
          text: 'Contactar Asesor',
          href: `https://wa.me/${whatsappAdviceNumber}`,
          target: '_blank',
        }
      },
      {
        title: 'Enfermería y Sueroterapia',
        description: 'Salud a domicilio con ali-com.',
        icon: 'tabler:first-aid-kit',
        callToAction: {
          text: 'Ver sitio oficial',
          href: 'https://ali-com.vercel.app/',
          target: '_blank',
        }
      },
    ]}
  />

  <!-- Location Section -->
  <Features2
    id="ubicacion"
    title="¿Dónde encontrarnos?"
    subtitle="C. Escondida 73, La Perla, 57820 Cdad. Nezahualcóyotl, Méx."
    tagline="Ubicación"
    items={[
      {
        title: 'Contacto Directo',
        description: `Psic. Ana Lilia Ortiz: +52 55 8706 8246 <br> Clínica: +52 55 2038 1691`,
        icon: 'tabler:phone',
      },
      {
        title: 'Horarios',
        description: 'Lunes a Viernes: 9:00 - 19:00 <br> Sábados: previa cita',
        icon: 'tabler:clock',
      },
    ]}
  />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 mb-12">
    <div class="rounded-3xl overflow-hidden shadow-lg border border-pink-100 h-[450px]">
      <iframe 
        src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3762.662580795556!2d-98.98632612502692!3d19.42769498179267!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x85d1ddc62c3e1e93%3A0x6e7e6f8a7e0f2f7!2sC.%20Escondida%2073%2C%20La%20Perla%2C%2057820%20Cdad.%20Nezahualc%C3%B3yotl%2C%20M%C3%A9x.!5e0!3m2!1ses-419!2smx!4v1710967069123!5m2!1ses-419!2smx" 
        width="100%" 
        height="100%" 
        style="border:0;" 
        allowfullscreen="" 
        loading="lazy" 
        referrerpolicy="no-referrer-when-downgrade"
      ></iframe>
    </div>
  </div>

  <CallToAction
    actions={[
      {
        variant: 'primary',
        text: 'Contactar por WhatsApp',
        href: `https://wa.me/${whatsappClinicNumber}`,
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
    ]}
  >
    <Fragment slot="title">¿Listo para comenzar?</Fragment>
    <Fragment slot="subtitle">Agenda tu primera sesión y comienza tu camino al bienestar.</Fragment>
  </CallToAction>

  <!-- Floating Social Buttons -->
  <div class="fixed bottom-6 right-6 z-50 flex flex-col gap-3 items-center animate__animated animate__bounceInUp">
    <!-- Instagram -->
    <a
      href="https://www.instagram.com/contagiandobienestar"
      target="_blank"
      class="bg-gradient-to-tr from-[#f9ce34] via-[#ee2a7b] to-[#6228d7] text-white p-3 rounded-full shadow-lg hover:scale-110 transition-transform flex items-center justify-center"
      aria-label="Instagram"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
        <path d="M4 4m0 4a4 4 0 0 1 4 -4h8a4 4 0 0 1 4 4v8a4 4 0 0 1 -4 4h-8a4 4 0 0 1 -4 -4z"></path>
        <path d="M12 12m-3 0a3 3 0 1 0 6 0a3 3 0 1 0 -6 0"></path>
        <path d="M16.5 7.5l0 .01"></path>
      </svg>
    </a>
    <!-- Facebook -->
    <a
      href="https://www.facebook.com/aepi.sociedad"
      target="_blank"
      class="bg-[#1877F2] text-white p-3 rounded-full shadow-lg hover:scale-110 transition-transform flex items-center justify-center"
      aria-label="Facebook"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
        <path d="M7 10v4h3v7h4v-7h3l1 -4h-4v-2a1 1 0 0 1 1 -1h3v-4h-3a5 5 0 0 0 -5 5v2h-3"></path>
      </svg>
    </a>
    <!-- WhatsApp -->
    <a
      href={`https://wa.me/${whatsappClinicNumber}`}
      target="_blank"
      class="bg-green-500 text-white p-4 rounded-full shadow-lg hover:scale-110 transition-transform flex items-center justify-center"
      aria-label="WhatsApp"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" fill="none" stroke-linecap="round" stroke-linejoin="round">
        <path stroke="none" d="M0 0h24v24H0z" fill="none"></path>
        <path d="M3 21l1.65 -3.8a9 9 0 1 1 3.4 2.9l-5.05 .9"></path>
        <path d="M9 10a.5 .5 0 0 0 1 0v-1a.5 .5 0 0 0 -1 0v1a5 5 0 0 0 5 5h1a.5 .5 0 0 0 0 -1h-1a.5 .5 0 0 0 0 1"></path>
      </svg>
    </a>
  </div>
</Layout>

<style>
  html {
    scroll-behavior: smooth;
  }
  .highlight {
    position: relative;
    z-index: 1;
  }
  .highlight::after {
    content: '';
    position: absolute;
    bottom: 0px;
    left: 0;
    width: 100%;
    height: 30%;
    background-color: rgba(168, 85, 247, 0.2);
    z-index: -1;
    border-radius: 4px;
  }
</style>