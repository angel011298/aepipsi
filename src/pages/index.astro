---
import Layout from '~/layouts/PageLayout.astro';
import Hero from '~/components/widgets/Hero.astro';
import Features from '~/components/widgets/Features.astro';
import Content from '~/components/widgets/Content.astro';

const metadata = {
  title: 'AEPI - Centro Multidisciplinario | Amar y Educar con Psicología Integral',
  ignoreTitleTemplate: true,
};
---

<Layout metadata={metadata}>
  <Hero
    actions={[
      {
        variant: 'primary',
        text: 'Agendar Cita (WhatsApp)',
        href: 'https://wa.me/521XXXXXXXXXX', // No olvides poner el número real aquí
        target: '_blank',
        icon: 'tabler:brand-whatsapp',
      },
      { text: 'Nuestros Servicios', href: '#servicios' },
    ]}
    image={{ src: '~/assets/images/image-team.jpeg', alt: 'Equipo Multidisciplinario AEPI' }}
  >
    <Fragment slot="title">
      Amar y Educar con <br />
      <span class="text-accent dark:text-white highlight">Psicología Integral</span> (AEPI)
    </Fragment>

    <Fragment slot="subtitle">
      Un espacio dedicado al bienestar emocional, desarrollo y aprendizaje de niños, adolescentes y adultos en un entorno cálido y profesional.
    </Fragment>
  </Hero>

  <Features
  id="servicios"
  tagline="Nuestras Especialidades"
  title="Atención Multidisciplinaria Integral"
  subtitle="Un equipo de profesionales dedicados al cuidado de tu familia."
  items={[
    {
      title: 'Psicología Clínica y de la Salud',
      description: 'Atención terapéutica para niños, adolescentes y adultos.',
      icon: 'tabler:heart-handshake',
    },
    {
      title: 'Terapia y Estimulación del Lenguaje',
      description: 'Diagnóstico y tratamiento de trastornos de comunicación.',
      icon: 'tabler:message-circle-2',
    },
    {
      title: 'Fisioterapia y Rehabilitación',
      description: 'Incluye termoterapia, electroterapia y masajes terapéuticos.',
      icon: 'tabler:activity',
    },
    {
      title: 'Estimulación Temprana y Prenatal',
      description: 'Acompañamiento en las etapas cruciales del desarrollo infantil.',
      icon: 'tabler:baby-carriage',
    },
    {
      title: 'Nutrición',
      description: 'Planes alimenticios enfocados en la salud integral.',
      icon: 'tabler:apple',
    },
    {
      title: 'Regularización Escolar',
      description: 'Apoyo académico para fortalecer el aprendizaje.',
      icon: 'tabler:school',
    },
    {
      title: 'Asesoría Jurídica',
      description: 'Acompañamiento legal especializado.',
      icon: 'tabler:gavel',
    },
  ]}
/>

<Features2
  title="¿Dónde encontrarnos?"
  subtitle="Visítanos en nuestras instalaciones o contáctanos para una cita."
  tagline="Ubicación"
  items={[
    {
      title: 'Dirección',
      description: 'Escribe aquí la dirección real de la clínica AEPI.',
      icon: 'tabler:map-pin',
    },
    {
      title: 'Horarios de Atención',
      description: 'Lunes a Viernes: 9:00 AM - 7:00 PM <br /> Sábados: 9:00 AM - 2:00 PM',
      icon: 'tabler:clock',
    },
    {
      title: 'Teléfono / WhatsApp',
      description: '+52 1 XX XXXX XXXX',
      icon: 'tabler:brand-whatsapp',
    },
  ]}
/>

  <Content
    id="equipo"
    isReversed
    tagline="Nuestro Equipo"
    title="Profesionales comprometidos contigo"
    items={[
      {
        title: 'Especialidades:',
        description: 'Estimulación Temprana, Terapia de Lenguaje y Regularización Escolar.',
      },
    ]}
    image={{
      src: '~/assets/images/image_ana-laura.jpeg',
      alt: 'Lic. Ana Laura - AEPI',
    }}
  >
    <Fragment slot="content">
      <h3 class="text-2xl font-bold tracking-tight dark:text-white sm:text-3xl mb-2">Lic. Ana Laura</h3>
      <p>Liderando la atención en desarrollo infantil y aprendizaje.</p>
    </Fragment>
  </Content>
</Layout>