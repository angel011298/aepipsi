---
import '@fontsource-variable/outfit';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Outfit Variable';
    --aw-font-serif: 'Outfit Variable';
    --aw-font-heading: 'Outfit Variable';

    --aw-color-primary: rgb(233 30 99); /* #E91E63 Pink */
    --aw-color-secondary: rgb(107 70 193); /* #6B46C1 Purple */
    --aw-color-accent: rgb(233 30 99);

    --aw-color-text-heading: rgb(0 0 0);
    --aw-color-text-default: rgb(16 16 16);
    --aw-color-text-muted: rgb(16 16 16 / 66%);
    --aw-color-bg-page: rgb(255 255 255);

    --aw-color-bg-page-dark: rgb(3 6 32);

    ::selection {
      background-color: lavender;
    }
  }

  .dark {
    --aw-font-sans: 'Outfit Variable';
    --aw-font-serif: 'Outfit Variable';
    --aw-font-heading: 'Outfit Variable';

    --aw-color-primary: rgb(233 30 99);
    --aw-color-secondary: rgb(107 70 193);
    --aw-color-accent: rgb(233 30 99);

    --aw-color-text-heading: rgb(247, 248, 248);
    --aw-color-text-default: rgb(229 236 246);
    --aw-color-text-muted: rgb(229 236 246 / 66%);
    --aw-color-bg-page: rgb(3 6 32);

    ::selection {
      background-color: black;
      color: snow;
    }
  }
</style>
