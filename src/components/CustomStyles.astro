---
import '@fontsource-variable/outfit';

// 'DM Sans'
// Nunito
// Dosis
// Outfit
// Roboto
// Literata
// 'IBM Plex Sans'
// Karla
// Poppins
// 'Fira Sans'
// 'Libre Franklin'
// Inconsolata
// Raleway
// Oswald
// 'Space Grotesk'
// Urbanist
---

<style is:inline>
  :root {
    --aw-font-sans: 'Outfit Variable';
    --aw-font-serif: 'Outfit Variable';
    --aw-font-heading: 'Outfit Variable';

    --aw-color-primary: #ed4c89; /* Pink AEPI */
    --aw-color-secondary: #7e22ce; /* Purple */
    --aw-color-accent: #a855f7;

    --aw-color-text-heading: #3b0764; /* Uva Oscuro */
    --aw-color-text-default: #581c87;
    --aw-color-text-muted: #7e22ce;
    --aw-color-bg-page: #fff5f8;

    --aw-color-bg-page-dark: #fff5f8;

    ::selection {
      background-color: lavender;
    }
  }

  .dark {
    --aw-font-sans: 'Outfit Variable';
    --aw-font-serif: 'Outfit Variable';
    --aw-font-heading: 'Outfit Variable';

    --aw-color-primary: #ed4c89;
    --aw-color-secondary: #7e22ce;
    --aw-color-accent: #a855f7;

    --aw-color-text-heading: #3b0764;
    --aw-color-text-default: #581c87;
    --aw-color-text-muted: #7e22ce;
    --aw-color-bg-page: #fff5f8;

    ::selection {
      background-color: black;
      color: snow;
    }
  }
</style>
