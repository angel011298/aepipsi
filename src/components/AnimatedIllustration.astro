---
import fs from 'node:fs';
import path from 'node:path';

interface Props {
  type: 'psychologist' | 'marriage-counseling' | 'group-therapy';
  class?: string;
}

const { type, class: className } = Astro.props;

// Path to assets
const assetsDir = path.resolve('./src/assets/images');
const svgPath = path.join(assetsDir, `${type}-not-css.svg`);
const cssPath = path.join(assetsDir, `${type}-styles.css`);

// Read contents
let svgContent = '';
let cssContent = '';

try {
  svgContent = fs.readFileSync(svgPath, 'utf-8');
  cssContent = fs.readFileSync(cssPath, 'utf-8');
} catch (error) {
  console.error(`Error loading assets for ${type}:`, error);
}

// Clean up SVG content (remove class="animated" if present to control it with JS)
svgContent = svgContent.replace('class="animated"', '').replace('<svg ', '<svg class="animable-svg" ');
---

<div class={`illustration-container ${type} ${className || ''}`} data-animate>
  <style is:inline set:html={cssContent} />
  <Fragment set:html={svgContent} />
</div>

<style is:global>
  .illustration-container svg {
    width: 100%;
    height: auto;
    overflow: visible;
  }
</style>

<script>
  const observerOptions = {
    root: null,
    rootMargin: '0px',
    threshold: 0.2
  };

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        const container = entry.target;
        const svg = container.querySelector('svg');
        if (svg) {
          svg.classList.add('animated');
        }
        observer.unobserve(container);
      }
    });
  }, observerOptions);

  document.querySelectorAll('[data-animate]').forEach(el => {
    observer.observe(el);
  });
</script>

