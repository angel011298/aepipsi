---
const { type = 'meditation', class: className = '' } = Astro.props;
---

<div class={className}>
  {type === 'meditation' && (
    <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
      <path d="M100 60c-15 0-25 10-25 25s10 25 25 25 25-10 25-25-10-25-25-25z" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
      <path d="M100 110c-30 0-50 20-50 50h100c0-30-20-50-50-50z" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
      <path d="M70 140c-10 0-20 10-20 20s10 10 20 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
      <path d="M130 140c10 0 20 10 20 20s-10 10-20 10" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
      <path d="M100 30c0 10 10 10 10 20s-10 10-10 20" stroke="currentColor" stroke-width="2" stroke-dasharray="4 4"/>
    </svg>
  )}
  {type === 'stretching' && (
    <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
      <path d="M60 40c0 10 10 20 20 20s20-10 20-20-10-20-20-20-20 10-20 20z" stroke="currentColor" stroke-width="3"/>
      <path d="M80 60v60M80 80l-40 20M80 80l40 20" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
      <path d="M80 120l-30 40M80 120l30 40" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
    </svg>
  )}
  {type === 'nutrition' && (
    <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
      <path d="M100 40c-10 0-15 10-15 20s5 20 15 20 15-10 15-20-5-20-15-20z" stroke="currentColor" stroke-width="3"/>
      <path d="M100 80v40h-20c-10 0-20 10-20 20v20h80v-20c0-10-10-20-20-20h-20" stroke="currentColor" stroke-width="3"/>
      <path d="M140 100c10 0 20 10 20 20s-10 20-20 20-20-10-20-20 10-20 20-20zM140 100l5-10" stroke="currentColor" stroke-width="3"/>
    </svg>
  )}
  {type === 'child' && (
    <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full h-full">
      <circle cx="70" cy="60" r="20" stroke="currentColor" stroke-width="3"/>
      <circle cx="130" cy="100" r="15" stroke="currentColor" stroke-width="3"/>
      <path d="M70 80v60M130 115v25" stroke="currentColor" stroke-width="3"/>
      <path d="M70 100h60" stroke="currentColor" stroke-width="3" stroke-dasharray="5 5"/>
    </svg>
  )}
</div>
